# ── Fraštačan environment variables ───────────────────────────────────
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# NEVER commit the real .env file — it is in .gitignore on purpose.

# SQLite database connection string.
#   Local dev:        file:./db/custom.db
#   Absolute path:    file:/home/user/frastacan/db/custom.db
#   Vercel/CI:        use a writable temp directory, e.g.
#                     file:/tmp/frastacan.db (data will be ephemeral!)
#                     For production, switch to PostgreSQL by changing
#                     the `provider` in prisma/schema.prisma and using:
#                     postgresql://user:pass@host:5432/frastacan
DATABASE_URL="file:./db/custom.db"

# ── Session token signing secret ──────────────────────────────────────
# REQUIRED for authentication. Must be at least 32 characters long.
# Generate one with:
#   bun -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# or:
#   openssl rand -hex 48
TOKEN_SECRET="replace-with-a-long-random-hex-string-at-least-32-chars"

# ── Node environment ──────────────────────────────────────────────────
NODE_ENV="development"
