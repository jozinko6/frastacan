# Prisma database URL
# Pre lokálny vývoj: SQLite súbor v db/ adresári (relatívna cesta od root projektu)
# Pre produkciu (Vercel/PostgreSQL): nahraďte za PostgreSQL connection string
#   príklad: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL="file:./db/custom.db"

# JWT/Session secret pre tokeny (pre produkciu generujte náhodný 32+ znakový reťazec)
# Pre lokálne demo tu môže byť ľubovoľná hodnota.
# AUTH_SECRET="zmente-ma-v-produkcii"

# NextAuth (ak by sa v budúcnosti použivalo)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="zmente-ma-v-produkcii"
